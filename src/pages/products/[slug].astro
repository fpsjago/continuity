---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.id }, props: { p } }));
}
const { p } = Astro.props;
const d = p.data;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const block = [
  ['SKU', d.sku],
  ['CATEGORY', d.category],
  ['STANDARD', d.standard],
  ['SHEET', '01 OF 01'],
  ['SCALE', '1:3'],
  ['REV', 'C'],
];
---

<Page title={`${d.name} — Spec Sheet — CONTINUITY`} description={d.tagline}>
  <section class="relative pt-16 pb-10 overflow-hidden border-b border-[var(--line)]">
    <div class="blueprint-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div class="container relative z-10">
      <a href={`${base}products`} class="mono text-[0.66rem] text-[var(--muted)] hover:text-[var(--ink)] transition-colors">← BACK TO INDEX</a>
      <div class="mt-6 grid lg:grid-cols-[1.3fr_0.7fr] gap-10 items-end">
        <div>
          <span class="kicker block mb-3">Spec Sheet · {d.category}</span>
          <h1 class="text-[clamp(2.2rem,5vw,4rem)] leading-[1] max-w-[18ch]">{d.name}</h1>
          <p class="mt-5 max-w-[42rem] text-[var(--text)]/80 text-[1.05rem]">{d.tagline}</p>
        </div>
        <div class="caliper"><span class="caliper__label">{d.sku}</span><div class="caliper__rule"></div><span class="caliper__label">{d.standard}</span></div>
      </div>
    </div>
  </section>

  <section class="py-16 atmos-glow">
    <div class="container grid lg:grid-cols-[1fr_1fr] gap-14 items-start">
      <div>
        <h2 class="font-[var(--font-mono)] text-[0.8rem] tracking-[0.16em] uppercase text-[var(--accent)] mb-5">Specifications</h2>
        <table class="w-full border-t border-[var(--line-strong)]">
          <tbody>
            {d.specs.map((s) => (
              <tr class="border-b border-[var(--line)]">
                <th scope="row" class="text-left py-3.5 pr-4 font-[var(--font-mono)] text-[0.72rem] tracking-[0.06em] uppercase text-[var(--muted)] align-top font-normal">{s.label}</th>
                <td class="py-3.5 font-[var(--font-mono)] text-[0.9rem] text-[var(--ink)] text-right">{s.value}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="titleblock grid grid-cols-3 border-l mt-10">
          {block.map(([k, v]) => (
            <div class="titleblock__cell"><div class="titleblock__k">{k}</div><div class="titleblock__v">{v}</div></div>
          ))}
        </div>
      </div>

      <aside class="lg:sticky lg:top-24">
        <div class="border border-[var(--line-strong)] rounded-[14px] p-7 bg-[var(--surface)] shimmer-border">
          <span class="status-token" data-state="live"><span class="dot"></span> IN STOCK · CERTIFIED</span>
          <h3 class="text-[1.5rem] mt-4">Need this on a project?</h3>
          <p class="text-[var(--text)]/75 text-[0.92rem] mt-2">Request a stamped spec sheet and a quote. We answer with numbers, not brochures.</p>
          <a href={`${base}request`} class="mt-6 inline-flex w-full justify-center items-center gap-2 bg-[var(--primary)] text-white font-semibold px-6 py-3.5 rounded-[10px] hover:-translate-y-0.5 transition-transform">Request spec sheet</a>
          <a href={`${base}contact`} class="mt-3 inline-flex w-full justify-center items-center gap-2 font-semibold px-6 py-3.5 rounded-[10px] border border-[var(--line-strong)] hover:border-[var(--ink)] transition-colors">Talk to engineering</a>
        </div>
      </aside>
    </div>
  </section>
</Page>
