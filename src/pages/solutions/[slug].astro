---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import PageHeader from '../../components/PageHeader.astro';

export async function getStaticPaths() {
  const solutions = await getCollection('solutions');
  return solutions.map((s) => ({ params: { slug: s.id }, props: { s } }));
}
const { s } = Astro.props;
const d = s.data;
const { Content } = await render(s);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Page title={`${d.title} — CONTINUITY`} description={d.summary}>
  <PageHeader plate={`Solution · ${d.plate}`} title={d.title} intro={d.summary} />
  {d.image && (
    <div class="container -mt-4">
      <div class="rounded-[18px] overflow-hidden border border-[var(--line)] aspect-[21/9] relative">
        <Picture src={d.image} formats={["avif","webp"]} alt={d.title} width={1480} height={634} class="w-full h-full object-cover" />
        <div class="absolute inset-0" style="background:linear-gradient(90deg,rgba(8,21,46,0.35),transparent 60%)"></div>
      </div>
    </div>
  )}
  <section class="py-16 atmos-glow">
    <div class="container grid lg:grid-cols-[1.4fr_0.6fr] gap-14 items-start">
      <div class="prose-body max-w-[44rem] text-[1.05rem] leading-relaxed text-[var(--text)]/85 space-y-5">
        <Content />
      </div>
      <aside class="border border-[var(--line-strong)] rounded-[14px] p-7 bg-[var(--surface)]">
        <h3 class="font-[var(--font-mono)] text-[0.72rem] tracking-[0.14em] uppercase text-[var(--accent)] mb-4">Capabilities</h3>
        <ul class="space-y-3">
          {d.capabilities.map((c) => (
            <li class="flex items-start gap-3 text-[0.92rem]"><span class="text-[var(--primary)] font-bold">+</span>{c}</li>
          ))}
        </ul>
        <a href={`${base}request`} class="mt-7 inline-flex w-full justify-center bg-[var(--primary)] text-white font-semibold px-6 py-3.5 rounded-[10px] hover:-translate-y-0.5 transition-transform">Request a spec sheet</a>
      </aside>
    </div>
  </section>
</Page>
