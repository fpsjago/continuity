---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Page from '../../layouts/Page.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProductGrid from '../../components/ProductGrid.tsx';

const entries = (await getCollection('products')).sort((a, b) => a.data.order - b.data.order);
const order = ['Surveillance', 'Cabling', 'Connectors', 'Fiber', 'Switching', 'Networking', 'Access'];
const cats = order.filter((c) => entries.some((p) => p.data.category === c));

const products = [];
for (const p of entries) {
  const img = p.data.image ? (await getImage({ src: p.data.image, format: 'webp', width: 560 })).src : undefined;
  products.push({ slug: p.id, name: p.data.name, sku: p.data.sku, category: p.data.category, tagline: p.data.tagline, specs: p.data.specs, img });
}
---

<Page title="Catalog — CONTINUITY" description="The CONTINUITY catalog: cameras, cabling, fiber, switching, racks and access hardware — each with a full spec sheet. Add to cart and request pricing on WhatsApp.">
  <PageHeader
    plate="Index · Catalog"
    title="The product catalog."
    intro="Cameras, cabling, fiber, switching, racks and access control. Filter by system, add what you need to your cart, and request pricing on WhatsApp — no checkout, no payment."
  />
  <section class="py-16 atmos-glow overflow-hidden">
    <div class="bgtype text-[clamp(5rem,15vw,13rem)] top-[3%] right-[-2%]" aria-hidden="true">INDEX</div>
    <div class="container relative z-10">
      <ProductGrid products={products} cats={cats} client:visible />
    </div>
  </section>
</Page>
