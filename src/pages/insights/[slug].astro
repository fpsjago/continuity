---
import { getCollection, render } from 'astro:content';
import Page from '../../layouts/Page.astro';
import PageHeader from '../../components/PageHeader.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const fmt = d.date.toLocaleDateString('en-US', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Page title={`${d.title} — CONTINUITY`} description={d.excerpt}>
  <PageHeader plate={`Insight · ${d.author}`} title={d.title} />
  <section class="py-16 atmos-glow">
    <div class="container max-w-[46rem]">
      <p class="mono text-[0.66rem] text-[var(--muted)] mb-8">{fmt} · {d.author}</p>
      <div class="prose-body text-[1.12rem] leading-[1.7] text-[var(--text)]/88 space-y-6">
        <p class="text-[1.3rem] leading-[1.6] text-[var(--ink)]">{d.excerpt}</p>
        <Content />
      </div>
      <a href={`${base}insights`} class="mono text-[0.66rem] text-[var(--muted)] hover:text-[var(--ink)] mt-12 inline-block">← ALL FIELD NOTES</a>
    </div>
  </section>
</Page>
