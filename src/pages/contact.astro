---
import Page from '../layouts/Page.astro';
import PageHeader from '../components/PageHeader.astro';
import RequestForm from '../components/RequestForm.tsx';
const rows = [
  ['Sales & quotes', 'sales@continuity.example', 'Spec sheets, pricing, availability'],
  ['Engineering', 'eng@continuity.example', 'Design support, test reports, standards'],
  ['General', 'hello@continuity.example', 'Everything else'],
];
---

<Page title="Contact — CONTINUITY" description="Talk to engineering. We answer with numbers.">
  <PageHeader plate="Plate · Contact" title="Talk to engineering." intro="Tell us what the link has to do. We answer with numbers, a spec sheet, and a date." />
  <section class="py-16 atmos-glow-top">
    <div class="container grid lg:grid-cols-[0.85fr_1.15fr] gap-14 items-start">
      <div>
        <h2 class="font-[var(--font-mono)] text-[0.72rem] tracking-[0.16em] uppercase text-[var(--accent)] mb-5">Direct lines</h2>
        <div class="border-t border-[var(--line-strong)]">
          {rows.map(([h, e, n], i) => (
            <div class="py-6 border-b border-[var(--line)]">
              <div class="flex items-baseline gap-3 mb-1"><span class="mono text-[0.62rem] text-[var(--primary)]">{String(i + 1).padStart(2, '0')}</span><h3 class="text-[1.15rem]">{h}</h3></div>
              <a href={`mailto:${e}`} class="font-[var(--font-mono)] text-[0.9rem] text-[var(--ink)] hover:text-[var(--primary)] transition-colors">{e}</a>
              <p class="text-[var(--muted)] text-[0.84rem] mt-0.5">{n}</p>
            </div>
          ))}
        </div>
        <div class="mt-8 flex flex-col gap-2 text-[var(--muted)]">
          <p class="font-[var(--font-mono)] text-[0.8rem]">📞 +1 (000) 000-0000</p>
          <p class="font-[var(--font-mono)] text-[0.8rem]">📍 Panama City · Global delivery</p>
        </div>
        <div class="caliper mt-8 max-w-[26rem]"><span class="caliper__label">MON–FRI</span><div class="caliper__rule"></div><span class="caliper__label">08:00–17:00</span></div>
      </div>

      <div class="border border-[var(--line-strong)] rounded-[16px] p-8 bg-[var(--surface)] shimmer-border">
        <h2 class="text-[1.6rem] mb-1">Send a message</h2>
        <p class="text-[var(--text)]/75 text-[0.92rem] mb-7">Tell us the part or system and what it has to do. An engineer replies, not a bot.</p>
        <RequestForm client:visible />
      </div>
    </div>
  </section>
</Page>
