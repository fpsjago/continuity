---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CartDrawer from '../components/CartDrawer.tsx';

interface Props {
  title?: string;
  description?: string;
  skin?: 'light' | 'dark';
  bodyClass?: string;
}
const {
  title = 'CONTINUITY — Network Infrastructure & Security Hardware',
  description = 'Structured cabling, fiber, connectors, racks, managed switches, CCTV and access control. Tested to 10 Gbps over 100m. Certified, not claimed.',
  skin = 'light',
  bodyClass = '',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Continuity',
  description,
  url: Astro.site?.href,
};
---

<!doctype html>
<html lang="en" data-skin={skin === 'dark' ? 'dark' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(org)} is:inline />
    <ClientRouter />
  </head>
  <body class:list={['grain', 'edge-fades', bodyClass]}>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot name="nav" />
    <main id="main"><slot /></main>
    <slot name="footer" />
    <CartDrawer client:load transition:persist="quote-cart" />

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const coarse = window.matchMedia('(pointer: coarse)').matches;
      document.documentElement.dataset.coarse = coarse ? 'true' : 'false';

      let lenis: any = null;
      let rafCb: any = null;

      function initMotion() {
        if (reduce || lenis) return;
        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });
        (window as any).__lenis = lenis;
        lenis.on('scroll', ScrollTrigger.update);
        rafCb = (time: number) => lenis && lenis.raf(time * 1000);
        gsap.ticker.add(rafCb);
        gsap.ticker.lagSmoothing(0);
        const refresh = () => ScrollTrigger.refresh();
        if ((document as any).fonts?.ready) (document as any).fonts.ready.then(refresh);
        requestAnimationFrame(refresh);
      }

      function destroyMotion() {
        ScrollTrigger.getAll().forEach((t) => t.kill());
        if (lenis) {
          if (rafCb) gsap.ticker.remove(rafCb);
          lenis.destroy();
          lenis = null;
          (window as any).__lenis = null;
        }
      }

      // runs on first load AND after every view transition
      document.addEventListener('astro:page-load', initMotion);
      document.addEventListener('astro:before-swap', destroyMotion);

      let lastW = window.innerWidth;
      window.addEventListener('resize', () => {
        if (window.innerWidth !== lastW) {
          lastW = window.innerWidth;
          ScrollTrigger.refresh();
        }
      });
    </script>
  </body>
</html>
